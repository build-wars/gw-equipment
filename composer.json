{
	"$schema": "https://getcomposer.org/schema.json",
	"name": "buildwars/gw-equipment",
	"description": "A PHP Library template/boilerplate.",
	"license": "MIT",
	"type": "library",
	"keywords": ["guild wars"],
	"authors": [
		{
			"name": "smiley",
			"email": "smiley@chillerlan.net",
			"homepage": "https://github.com/codemasher"
		},
		{
			"name": "Contributors",
			"homepage":"https://github.com/build-wars/gw-equipment/graphs/contributors"
		}
	],
	"funding": [
		{
			"type": "Ko-Fi",
			"url": "https://ko-fi.com/codemasher"
		}
	],
	"homepage": "https://github.com/build-wars/gw-equipment",
	"support": {
		"issues": "https://github.com/build-wars/gw-equipment/issues",
		"source": "https://github.com/build-wars/gw-equipment"
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"require": {
		"php": "^8.1",
		"ext-sodium": "*",
		"buildwars/gw-templates": "^1.0"
	},
	"require-dev": {
		"phan/phan": "^6.0.5",
		"phpmd/phpmd": "^2.15",
		"phpunit/phpunit": "^11.5",
		"slevomat/coding-standard": "^8.29",
		"squizlabs/php_codesniffer": "^4.0"
	},
	"suggest": {
	},
	"autoload": {
		"psr-4": {
			"Buildwars\\GWEquipment\\": "src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Buildwars\\GWEquipmentTest\\": "tests"
		}
	},
	"scripts": {
		"phan": "@php vendor/bin/phan",
		"phpcs": "@php vendor/bin/phpcs -v",
		"phpunit": "@php vendor/bin/phpunit"
	},
	"config": {
		"lock": false,
		"sort-packages": true,
		"platform-check": true,
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
